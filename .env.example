# Firebase Auth
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Kakao Map API (https://developers.kakao.com → 앱 생성 → JavaScript 키)
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_javascript_key

# Public Data API Key (data.go.kr 공공데이터포털 통합 인증키)
DATA_GO_KR_API_KEY=your_data_go_kr_key

# PQC / Hospital Portal (npm run crypto:keygen in backend)
HOSPITAL_MLKEM_PUBLIC_KEY=your_mlkem_public_key_base64
HOSPITAL_MLKEM_PRIVATE_KEY=your_mlkem_private_key_base64
HOSPITAL_JWT_SECRET=your_hospital_jwt_secret
HOSPITAL_DEMO_EMAIL=hospital@meditech.local
HOSPITAL_DEMO_PASSWORD=meditech2026
PII_ENCRYPTION_VERSION=1
CONSENT_VERSION=2026-05-31
IP_HASH_SALT=meditech_salt

# Frontend API
NEXT_PUBLIC_API_URL=http://localhost:3001/api
